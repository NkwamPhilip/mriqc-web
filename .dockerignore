# Build artefacts the image creates itself
node_modules/
dist/

# Python virtualenv and caches
.venv/
__pycache__/
*.pyc
*.pyo

# Git history — not needed in the image
.git/
.gitignore

# Local dev / CI secrets
.env
.env.local
.env.*

# Render / Vercel CI helpers (not needed inside Docker)
bin/
render.yaml
vercel.json
setup_render.sh
local_server.py

# Editor / IDE
.claude/
.vscode/
.idea/

# Accidental directories
path/

# Test outputs and temp files
/tmp/
*.log
